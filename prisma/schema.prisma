// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model State {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  abbreviation String   @unique @db.VarChar(2)
  fipsCode     String?  @unique @db.VarChar(2)
  counties     County[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("states")
}

model County {
  id        String   @id @default(uuid())
  stateId   String
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  fipsCode  String?  @unique @db.VarChar(5)
  courts    Court[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stateId, slug])
  @@index([stateId])
  @@map("counties")
}

enum CourtLevel {
  SUPREME
  APPELLATE
  TRIAL
  SPECIALIZED
}

model Court {
  id        String      @id @default(uuid())
  countyId  String
  county    County      @relation(fields: [countyId], references: [id], onDelete: Cascade)
  type      String
  slug      String
  level     CourtLevel?
  judges    Judge[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([countyId, slug])
  @@index([countyId])
  @@map("courts")
}

enum JudgeStatus {
  UNVERIFIED
  VERIFIED
  NEEDS_REVIEW
  REJECTED
}

enum HarvestJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum HarvestTrigger {
  ADMIN
  CRON
  CLI
}

enum SourceAuthority {
  OFFICIAL_GOV      // Official government source (FJC, Congress.gov, state judiciary)
  COURT_WEBSITE     // Individual court website
  ELECTION_RECORDS  // Secretary of State / election data
  SECONDARY         // News, bar associations, etc.
}

model HarvestJob {
  id              String           @id @default(uuid())
  stateAbbr       String           @db.VarChar(2)
  state           String
  status          HarvestJobStatus @default(QUEUED)
  triggeredBy     HarvestTrigger   @default(ADMIN)

  urlsTotal       Int              @default(0)
  urlsProcessed   Int              @default(0)
  urlsFailed      Int              @default(0)
  judgesFound     Int              @default(0)
  judgesNew       Int              @default(0)
  judgesUpdated   Int              @default(0)

  startedAt       DateTime?
  completedAt     DateTime?

  reportMarkdown  String?          @db.Text
  errorMessage    String?          @db.Text

  judges          Judge[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([stateAbbr])
  @@index([status])
  @@index([createdAt])
  @@index([stateAbbr, status])
  @@map("harvest_jobs")
}

model Judge {
  id                   String       @id @default(uuid())
  courtId              String
  court                Court        @relation(fields: [courtId], references: [id], onDelete: Cascade)
  fullName             String
  slug                 String
  
  // Term & Selection
  termStart            DateTime?
  termEnd              DateTime?
  selectionMethod      String?
  appointingAuthority  String?
  appointmentDate      DateTime?
  
  // Biographical
  birthDate            DateTime?
  photoUrl             String?
  education            String?      @db.Text
  priorExperience      String?      @db.Text
  politicalAffiliation String?
  barAdmissionDate     DateTime?
  barAdmissionState    String?
  
  // Court Assignment
  isChiefJudge         Boolean      @default(false)
  division             String?
  
  // Contact Information
  courthouseAddress    String?      @db.Text
  courthousePhone      String?
  
  // Source & Status
  sourceUrl            String?
  rosterUrl            String?
  sourceAuthority      SourceAuthority?
  extractionMethod     String?
  status               JudgeStatus  @default(UNVERIFIED)
  harvestJobId         String?
  harvestJob           HarvestJob?  @relation(fields: [harvestJobId], references: [id], onDelete: SetNull)
  
  // Confidence & Verification
  confidenceScore      Float?       // 0.0 - 1.0 overall confidence
  autoVerified         Boolean      @default(false)
  anomalyFlags         String[]     // Array of anomaly codes
  reviewReason         String?      // Why queued for manual review
  verifiedAt           DateTime?    // When verified (auto or manual)
  lastHarvestAt        DateTime?    // Last time data was refreshed from source
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([courtId, slug])
  @@index([courtId])
  @@index([fullName])
  @@index([harvestJobId])
  @@index([status])
  @@map("judges")
}

// ---------------------------------------------------------------------------
// URL Discovery & Scrape Failure Tracking (Feature 011)
// ---------------------------------------------------------------------------

enum CandidateStatus {
  DISCOVERED
  APPROVED
  REJECTED
}

enum FailureType {
  HTTP_403
  HTTP_429
  TIMEOUT
  CAPTCHA_DETECTED
  SSL_ERROR
  DNS_FAILURE
  EMPTY_PAGE
  PARSE_ERROR
  UNKNOWN
}

enum DiscoveryRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ---------------------------------------------------------------------------
// URL Health Scoring & Delta-Run Prioritization (Feature 012)
// ---------------------------------------------------------------------------

enum YieldTrend {
  IMPROVING
  STABLE
  DECLINING
}

enum HealthSource {
  DISCOVERED
  MANUAL
}

model UrlHealth {
  id                String       @id @default(uuid())
  url               String       @unique
  domain            String
  state             String
  stateAbbr         String       @db.VarChar(2)
  healthScore       Float        @default(0.5)
  totalScrapes      Int          @default(0)
  successfulScrapes Int          @default(0)
  lastYield         Int?
  avgYield          Float?
  yieldTrend        YieldTrend   @default(STABLE)
  anomalyDetected   Boolean      @default(false)
  anomalyMessage    String?
  lastScrapedAt     DateTime?
  lastSuccessAt     DateTime?
  source            HealthSource @default(MANUAL)
  active            Boolean      @default(true)
  scrapeLogs        ScrapeLog[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([stateAbbr, healthScore])
  @@index([healthScore])
  @@index([lastSuccessAt])
  @@index([anomalyDetected])
  @@index([active])
  @@map("url_health")
}

model ScrapeLog {
  id              String       @id @default(uuid())
  urlHealthId     String
  urlHealth       UrlHealth    @relation(fields: [urlHealthId], references: [id], onDelete: Cascade)
  url             String
  state           String
  stateAbbr       String       @db.VarChar(2)
  success         Boolean
  judgesFound     Int          @default(0)
  failureType     FailureType?
  httpStatusCode  Int?
  errorMessage    String?      @db.Text
  retryCount      Int          @default(0)
  scrapeDurationMs Int?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?      @db.Text
  scrapedAt       DateTime     @default(now())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([urlHealthId])
  @@index([url])
  @@index([stateAbbr, success])
  @@index([failureType])
  @@index([scrapedAt])
  @@index([resolvedAt])
  @@map("scrape_logs")
}

model UrlCandidate {
  id              String          @id @default(uuid())
  url             String          @unique
  domain          String
  state           String
  stateAbbr       String          @db.VarChar(2)
  suggestedType   String?
  suggestedLevel  String?
  confidenceScore Float?
  searchQuery     String
  snippetText     String?         @db.Text
  pageTitle       String?         
  status          CandidateStatus @default(DISCOVERED)
  rejectionReason String?         @db.Text
  reviewedAt      DateTime?
  promotedAt      DateTime?
  discoveryRunId  String
  discoveryRun    DiscoveryRun    @relation(fields: [discoveryRunId], references: [id])
  discoveredAt    DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Harvest pipeline fields
  scrapeWorthy      Boolean?
  autoClassifiedAt  DateTime?
  fetchMethod       String          @default("http")
  extractionHints   Json?
  lastYieldCount    Int?
  harvestAttempts   Int             @default(0)

  @@index([state])
  @@index([status])
  @@index([discoveredAt])
  @@index([stateAbbr, status])
  @@index([scrapeWorthy])
  @@map("url_candidates")
}

model DiscoveryRun {
  id              String             @id @default(uuid())
  state           String
  stateAbbr       String             @db.VarChar(2)
  status          DiscoveryRunStatus @default(RUNNING)
  queriesTotal    Int                @default(0)
  queriesRun      Int                @default(0)
  candidatesFound Int                @default(0)
  candidatesNew   Int                @default(0)
  startedAt       DateTime           @default(now())
  completedAt     DateTime?
  errorMessage    String?            @db.Text
  candidates      UrlCandidate[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([state])
  @@index([startedAt])
  @@map("discovery_runs")
}
